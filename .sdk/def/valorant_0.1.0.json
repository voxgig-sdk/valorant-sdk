{
  "openapi": "3.0.3",
  "info": {
    "title": "Valorant API",
    "description": "The Valorant API provides extensive data related to in-game items, assets, and other game features, sourced directly from the Valorant game files. This API automatically updates with each game patch, ensuring accurate and up-to-date information for developers and fans alike.",
    "version": "1.0.0",
    "contact": {
      "url": "https://dash.valorant-api.com/"
    }
  },
  "servers": [
    {
      "url": "https://valorant-api.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/v1/agents": {
      "get": {
        "summary": "Get all agents",
        "description": "Retrieve a list of all Valorant agents with their abilities, role, and other details",
        "operationId": "getAgents",
        "tags": [
          "Agents"
        ],
        "parameters": [
          {
            "name": "language",
            "in": "query",
            "description": "Language code for localized content (e.g., en-US, es-ES, fr-FR)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en-US"
            }
          },
          {
            "name": "isPlayableCharacter",
            "in": "query",
            "description": "Filter only playable characters",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of agents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "example": 200
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Agent"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/v1/agents/{uuid}": {
      "get": {
        "summary": "Get agent by UUID",
        "description": "Retrieve detailed information about a specific agent by their UUID",
        "operationId": "getAgentByUuid",
        "tags": [
